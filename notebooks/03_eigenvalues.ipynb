   "source": [
    "import numpy as np\n",
    "\n",
    "M = np.array([[2, 0],[0,3]])\n",
    "\n",
    "print(M)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "5a7a1299-dcb9-48d0-a6da-f6b8ba265c96",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[2. 3.] [[1. 0.]\n",
      " [0. 1.]]\n",
      "[2. 0.]\n",
      "[2. 0.]\n",
      "True\n"
     ]
    }
   ],
   "source": [
    "vals, vecs = np.linalg.eig(M)\n",
    "vals2, vecs2 = np.linalg.eigh(M)\n",
    "\n",
    "print(vals2, vecs2)\n",
    "\n",
    "a = M @ vecs[:, 0]\n",
    "b = vals[0] * vecs[:, 0]\n",
    "print(a)\n",
    "print(b)\n",
    "\n",
    "print(np.allclose(a,b))"
   ]
  },
